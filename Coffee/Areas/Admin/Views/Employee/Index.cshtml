@using FastFood.Areas.Admin.Controllers
@model List<EmployeeModel>
@{
    ViewData["Title"] = "Quản Lý Nhân Viên";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="admin-page">
    <div class="page-header-admin mb-4">
        <div>
            <h1 class="page-title">Quản Lý <span class="text-gradient">Nhân Viên</span></h1>
            <p class="text-muted mb-0">Danh sách nhân viên của CaféLux</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Thêm Nhân Viên
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="admin-card">
        <div class="table-responsive">
            <table class="table-premium">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Họ Tên</th>
                        <th>Chức Vụ</th>
                        <th>Email</th>
                        <th>SĐT</th>
                        <th>Lương Cơ Bản</th>
                        <th>Ngày Vào Làm</th>
                        <th>Trạng Thái</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@emp.Id</span></td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar-sm">@emp.HoTen.First()</div>
                                    <strong>@emp.HoTen</strong>
                                </div>
                            </td>
                            <td><span class="badge" style="background:rgba(212,168,83,0.2);color:#B8860B;border:1px solid #D4A853;">@emp.ChucVu</span></td>
                            <td>@emp.Email</td>
                            <td>@emp.SoDienThoai</td>
                            <td class="fw-semibold text-success">@emp.LuongCoBan.ToString("N0") ₫</td>
                            <td>@emp.NgayVaoLam.ToString("dd/MM/yyyy")</td>
                            <td>
                                <form asp-action="ToggleStatus" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@emp.Id" />
                                    <button type="submit" class="badge-custom @(emp.TrangThai ? "success" : "danger")" style="cursor:pointer; font-size:0.8rem;">
                                        @(emp.TrangThai ? "Đang làm" : "Nghỉ việc")
                                    </button>
                                </form>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-action="Edit" asp-route-id="@emp.Id" class="btn-action edit" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Xóa nhân viên này?')">
                                        <input type="hidden" name="id" value="@emp.Id" />
                                        <button type="submit" class="btn-action delete" title="Xóa">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
.user-avatar-sm {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, #D4A853, #B8860B);
    color: white; display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.85rem; flex-shrink: 0;
}
</style>
