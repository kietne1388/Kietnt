@model FastFood.Models.Category.UpdateCategoryModel

@{
    ViewData["Title"] = "Sửa Danh Mục";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="admin-page">
    <div class="page-header-admin mb-4">
        <div>
            <h1 class="page-title">Chỉnh Sửa <span class="text-gradient">Danh Mục</span></h1>
            <p class="text-muted mb-0">Cập nhật thông tin: <strong>@Model.Name</strong></p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary px-4">
            <i class="fas fa-arrow-left me-2"></i>Quay Lại
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="form-card">
                <div class="form-card-header">
                    <i class="fas fa-tags me-2"></i>Thông Tin Danh Mục
                </div>
                <div class="form-card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mb-3 rounded-3">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@err.ErrorMessage</div>
                            }
                        </div>
                    }
                    <form asp-action="Edit" method="post">
                        <input asp-for="Id" type="hidden" />
                        <div class="mb-4">
                            <label class="field-label">Tên Danh Mục <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control field-input"
                                   placeholder="VD: Cà phê, Trà sữa, Sinh tố..." required maxlength="100" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label class="field-label">Mô Tả</label>
                            <textarea asp-for="Description" class="form-control field-input" rows="4"
                                      placeholder="Mô tả ngắn về danh mục này..." maxlength="500"></textarea>
                            <div class="form-text">Tối đa 500 ký tự</div>
                        </div>
                        <div class="d-flex gap-3 pt-3 border-top">
                            <button type="submit" class="btn btn-warning text-white px-5 btn-action-submit">
                                <i class="fas fa-save me-2"></i>Lưu Thay Đổi
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="form-card">
                <div class="form-card-header">
                    <i class="fas fa-info-circle me-2"></i>Thông Tin Hiện Tại
                </div>
                <div class="form-card-body">
                    <div class="info-item">
                        <span class="info-label">ID Danh Mục</span>
                        <span class="info-value">#@Model.Id</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Tên hiện tại</span>
                        <span class="info-value fw-bold">@Model.Name</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_FormStyles")
<style>
.info-item { display: flex; justify-content: space-between; align-items: center; padding: 0.7rem 0; border-bottom: 1px solid #F3F4F6; }
.info-item:last-child { border-bottom: none; }
.info-label { font-size: 0.82rem; color: #9CA3AF; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
.info-value { font-size: 0.93rem; color: #111827; }
</style>
