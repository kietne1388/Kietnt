@model FastFood.Models.Category.CreateCategoryModel

@{
    ViewData["Title"] = "Thêm Danh Mục";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="admin-page">
    <div class="page-header-admin mb-4">
        <div>
            <h1 class="page-title">Thêm <span class="text-gradient">Danh Mục</span></h1>
            <p class="text-muted mb-0">Tạo danh mục sản phẩm mới cho CoffeeLux</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary px-4">
            <i class="fas fa-arrow-left me-2"></i>Quay Lại
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="form-card">
                <div class="form-card-header">
                    <i class="fas fa-tags me-2"></i>Thông Tin Danh Mục
                </div>
                <div class="form-card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mb-3 rounded-3">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@err.ErrorMessage</div>
                            }
                        </div>
                    }
                    <form asp-action="Create" method="post">
                        <div class="mb-4">
                            <label class="field-label">Tên Danh Mục <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control field-input"
                                   placeholder="VD: Cà phê, Trà sữa, Sinh tố..." required maxlength="100" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label class="field-label">Mô Tả</label>
                            <textarea asp-for="Description" class="form-control field-input" rows="4"
                                      placeholder="Mô tả ngắn về danh mục này..." maxlength="500"></textarea>
                            <div class="form-text">Tối đa 500 ký tự</div>
                        </div>
                        <div class="d-flex gap-3 pt-3 border-top">
                            <button type="submit" class="btn btn-primary px-5 btn-action-submit">
                                <i class="fas fa-plus me-2"></i>Thêm Danh Mục
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="form-card">
                <div class="form-card-header">
                    <i class="fas fa-lightbulb me-2"></i>Hướng Dẫn
                </div>
                <div class="form-card-body">
                    <ul class="guide-list">
                        <li><i class="fas fa-check-circle text-success me-2"></i>Đặt tên ngắn gọn, dễ nhớ</li>
                        <li><i class="fas fa-check-circle text-success me-2"></i>Mô tả rõ ràng các sản phẩm thuộc danh mục</li>
                        <li><i class="fas fa-check-circle text-success me-2"></i>Tránh trùng tên với danh mục đã có</li>
                        <li><i class="fas fa-info-circle text-primary me-2"></i>Tên tối đa 100 ký tự</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_FormStyles")
<style>
.guide-list { list-style: none; padding: 0; margin: 0; }
.guide-list li { padding: 0.6rem 0; border-bottom: 1px solid #F3F4F6; font-size: 0.9rem; color: #374151; }
.guide-list li:last-child { border-bottom: none; }
</style>
