@model IEnumerable<FastFood.Domain.Entities.Attendance>
@{
    ViewData["Title"] = "Quản Lý Chấm Công";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="fas fa-clock text-warning me-2"></i>Chấm Công Nhân Viên</h2>
            <p class="text-muted mb-0">Theo dõi thời gian làm việc và doanh thu lương (30.000đ/h)</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nhân Viên</th>
                            <th>Giờ Vào Ca</th>
                            <th>Giờ Ra Ca</th>
                            <th>Thời Gian</th>
                            <th>Lương Tạm Tính</th>
                            <th>Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                var elapsed = item.ClockOutTime.HasValue ? item.ClockOutTime.Value - item.ClockInTime : TimeSpan.Zero;
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm bg-light-brown text-brown rounded-circle d-flex align-items-center justify-content-center me-3" style="width:36px;height:36px;">
                                                @(item.Employee?.FullName?.Substring(0, 1) ?? "U")
                                            </div>
                                            <span class="fw-semibold">@(item.Employee?.FullName ?? "Unknown")</span>
                                        </div>
                                    </td>
                                    <td>@item.ClockInTime.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (item.ClockOutTime.HasValue)
                                        {
                                            @item.ClockOutTime.Value.ToString("dd/MM/yyyy HH:mm")
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Đang làm việc</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.ClockOutTime.HasValue)
                                        {
                                            <span>@((int)elapsed.TotalHours)h @elapsed.Minutes m</span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td class="text-success fw-bold">
                                        @if (item.ClockOutTime.HasValue)
                                        {
                                            @item.TotalSalary.ToString("N0") <text>đ</text>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onclick="return confirm('Bạn có chắc muốn xóa bản ghi này?');" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-history d-block fs-1 mb-2 text-black-50"></i>
                                    Chưa có dữ liệu chấm công.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .avatar-sm { font-weight: bold; background: #FAF7F2; color: #6F4E37; }
    .table-light { background-color: #fcfbfa !important; }
</style>
