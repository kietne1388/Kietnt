@using FastFood.Areas.Admin.Controllers
@model List<SalesReceiptModel>
@{
    ViewData["Title"] = "Quản Lý Phiếu Bán Hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="admin-page">
    <div class="page-header-admin mb-4">
        <div>
            <h1 class="page-title">Phiếu <span class="text-gradient">Bán Hàng</span></h1>
            <p class="text-muted mb-0">Danh sách phiếu bán hàng của CaféLux</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="admin-stat-card">
                <div class="stat-icon" style="background: linear-gradient(135deg, #D4A853, #B8860B);">
                    <i class="fas fa-file-invoice-dollar"></i>
                </div>
                <div class="stat-info">
                    <h3>@Model.Count</h3>
                    <p>Tổng Phiếu</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-stat-card">
                <div class="stat-icon" style="background: linear-gradient(135deg, #28a745, #20c997);">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="stat-info">
                    <h3>@Model.Count(r => r.TrangThai == "Hoàn Thành")</h3>
                    <p>Hoàn Thành</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-stat-card">
                <div class="stat-icon" style="background: linear-gradient(135deg, #ffc107, #fd7e14);">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-info">
                    <h3>@Model.Count(r => r.TrangThai == "Đang Xử Lý")</h3>
                    <p>Đang Xử Lý</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-stat-card">
                <div class="stat-icon" style="background: linear-gradient(135deg, #6610f2, #6f42c1);">
                    <i class="fas fa-money-bill-wave"></i>
                </div>
                <div class="stat-info">
                    <h3>@Model.Sum(r => r.TongTien).ToString("N0")₫</h3>
                    <p>Doanh Thu</p>
                </div>
            </div>
        </div>
    </div>

    <div class="admin-card">
        <div class="table-responsive">
            <table class="table-premium">
                <thead>
                    <tr>
                        <th>Mã Phiếu</th>
                        <th>Ngày Lập</th>
                        <th>Nhân Viên</th>
                        <th>Khách Hàng</th>
                        <th>Tổng Tiền</th>
                        <th>Trạng Thái</th>
                        <th>Ghi Chú</th>
                        <th>Chi Tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td><span class="badge bg-dark">#@r.Id</span></td>
                            <td>@r.NgayLap.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><i class="fas fa-user-tie me-1 text-muted"></i>@r.TenNhanVien</td>
                            <td>@r.TenKhachHang</td>
                            <td class="fw-bold text-success">@r.TongTien.ToString("N0") ₫</td>
                            <td>
                                @if (r.TrangThai == "Hoàn Thành")
                                {
                                    <span class="badge-custom success">@r.TrangThai</span>
                                }
                                else if (r.TrangThai == "Đang Xử Lý")
                                {
                                    <span class="badge-custom warning">@r.TrangThai</span>
                                }
                                else
                                {
                                    <span class="badge-custom danger">@r.TrangThai</span>
                                }
                            </td>
                            <td class="text-muted">@(string.IsNullOrEmpty(r.GhiChu) ? "—" : r.GhiChu)</td>
                            <td>
                                <div class="action-buttons justify-content-start text-start">
                                    <a asp-action="Detail" asp-route-id="@r.Id" class="btn-action edit" title="Chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
