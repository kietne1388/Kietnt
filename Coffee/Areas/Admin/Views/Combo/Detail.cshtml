@model FastFood.Models.Combo.ComboDetailModel

@{
    ViewData["Title"] = "Chi Tiết Combo - " + Model.Name;
}

<div class="admin-page">
    <div class="page-header-admin mb-4">
        <div>
            <a asp-action="Index" class="btn btn-sm btn-light mb-2">
                <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
            </a>
            <h1 class="page-title text-gradient">Chi Tiết Combo</h1>
        </div>
        <div class="header-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="fas fa-edit me-2"></i>Chỉnh sửa Combo
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Info Section -->
        <div class="col-lg-8">
            <div class="admin-card mb-4 overflow-hidden p-0">
                <div class="row g-0">
                    <div class="col-md-5">
                        <div class="combo-image-large">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" alt="@Model.Name" />
                            }
                            else
                            {
                                <div class="image-placeholder">
                                    <i class="fas fa-box-open fa-3x"></i>
                                    <span>Chưa có ảnh</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-md-7 p-4 h-100 d-flex flex-column">
                        <div class="mb-auto">
                            <span class="badge bg-danger-light text-danger mb-2">Combo Đặc Biệt</span>
                            <h2 class="mb-3">@Model.Name</h2>
                            <p class="text-muted leading-relaxed">@Model.Description</p>
                        </div>
                        
                        <div class="pricing-summary mt-4">
                            <div class="row g-3">
                                <div class="col-4">
                                    <div class="price-box">
                                        <label>Giá gốc</label>
                                        <div class="value original">@Model.OriginalPrice.ToString("N0")đ</div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="price-box highlight">
                                        <label>Giá Combo</label>
                                        <div class="value current">@Model.Price.ToString("N0")đ</div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="price-box saving">
                                        <label>Tiết kiệm</label>
                                        <div class="value">@((Model.OriginalPrice - Model.Price).ToString("N0"))đ</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="section-title-small m-0">Sản phẩm có trong Combo</h5>
                    <span class="badge bg-gray-100 text-gray-700">@Model.Items.Count() sản phẩm</span>
                </div>

                <div class="product-grid-detail">
                    @foreach (var item in Model.Items)
                    {
                        <div class="product-item-horizontal shadow-sm">
                            <div class="item-img">
                                @if (!string.IsNullOrEmpty(item.ProductImageUrl))
                                {
                                    <img src="@item.ProductImageUrl" alt="@item.ProductName" />
                                }
                                else
                                {
                                    <div class="img-none"><i class="fas fa-hamburger"></i></div>
                                }
                                <div class="quantity-badge">x@item.Quantity</div>
                            </div>
                            <div class="item-details">
                                <h6 class="m-0">@item.ProductName</h6>
                                <div class="item-meta">
                                    <span class="unit-price">@item.ProductPrice.ToString("N0")đ / món</span>
                                    <span class="total-line">Tổng: <strong>@((item.Quantity * item.ProductPrice).ToString("N0"))đ</strong></span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar Info -->
        <div class="col-lg-4">
            <div class="admin-card mb-4">
                <h5 class="section-title-small mb-4">Trạng thái & Cài đặt</h5>
                <div class="status-list">
                    <div class="status-row">
                        <span>Trạng thái hoạt động</span>
                        @if (Model.IsActive)
                        {
                            <span class="status-pill active"><i class="fas fa-check-circle me-1"></i>Đang bật</span>
                        }
                        else
                        {
                            <span class="status-pill inactive"><i class="fas fa-times-circle me-1"></i>Đang tắt</span>
                        }
                    </div>
                    <div class="status-row">
                        <span>ID Hệ thống</span>
                        <code class="text-primary font-bold">#@Model.Id</code>
                    </div>
                    <form asp-action="ToggleActive" asp-route-id="@Model.Id" method="post" class="mt-4">
                        <button type="submit" class="btn btn-outline-secondary w-100">
                            <i class="fas @(Model.IsActive ? "fa-eye-slash" : "fa-eye") me-2"></i>
                            @(Model.IsActive ? "Tạm ẩn Combo" : "Hiển thị Combo")
                        </button>
                    </form>
                </div>
            </div>

            <div class="admin-card bg-light-danger border-danger-subtle">
                <h5 class="text-danger mb-3 font-bold"><i class="fas fa-exclamation-triangle me-2"></i>Vùng nguy hiểm</h5>
                <p class="text-sm text-muted mb-4">Xóa combo sẽ không thể hoàn tác. Mọi đơn hàng cũ có combo này vẫn được giữ lại nhưng combo sẽ biến mất khỏi menu.</p>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa combo này?')">
                    <button type="submit" class="btn btn-danger w-100">
                        <i class="fas fa-trash-alt me-2"></i>Xóa Combo vĩnh viễn
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
.combo-image-large {
    width: 100%;
    height: 100%;
    min-height: 250px;
    background: #f8fafc;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.combo-image-large img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.image-placeholder {
    color: #cbd5e1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
}

.price-box {
    background: #f1f5f9;
    padding: 0.75rem;
    border-radius: 12px;
    text-align: center;
}

.price-box label {
    font-size: 0.75rem;
    color: #64748b;
    display: block;
    margin-bottom: 0.25rem;
    font-weight: 700;
}

.price-box .value {
    font-weight: 900;
    font-size: 1.1rem;
    color: #1e293b;
}

.price-box.highlight {
    background: var(--primary-red-lightest);
    border: 1px solid var(--primary-red-lighter);
}

.price-box.highlight .value {
    color: var(--primary-red);
    font-size: 1.25rem;
}

.price-box.saving .value {
    color: #10b981;
}

.price-box .value.original {
    text-decoration: line-through;
    color: #94a3b8;
}

.section-title-small {
    font-size: 1.1rem;
    font-weight: 800;
    color: #1e293b;
    border-left: 4px solid var(--primary-red);
    padding-left: 1rem;
}

.product-grid-detail {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
}

.product-item-horizontal {
    display: flex;
    background: white;
    border-radius: 12px;
    padding: 0.75rem;
    border: 1px solid #f1f5f9;
    transition: transform 0.2s;
}

.product-item-horizontal:hover {
    transform: translateX(5px);
    border-color: var(--primary-red-lighter);
}

.item-img {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    overflow: hidden;
    margin-right: 1rem;
    position: relative;
    background: #f8fafc;
    flex-shrink: 0;
}

.item-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.img-none {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: #cbd5e1;
}

.quantity-badge {
    position: absolute;
    bottom: 0;
    right: 0;
    background: var(--primary-red);
    color: white;
    font-size: 0.7rem;
    padding: 1px 5px;
    border-top-left-radius: 5px;
    font-weight: 900;
}

.item-details {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.item-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: #64748b;
    margin-top: 0.25rem;
}

.status-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.status-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.75rem;
    border-bottom: 1px dashed #e2e8f0;
}

.status-pill {
    padding: 4px 12px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 700;
}

.status-pill.active { background: #dcfce7; color: #166534; }
.status-pill.inactive { background: #fee2e2; color: #991b1b; }

.bg-light-danger { background-color: #fef2f2; }
.border-danger-subtle { border: 1px solid #fecaca; }
</style>
