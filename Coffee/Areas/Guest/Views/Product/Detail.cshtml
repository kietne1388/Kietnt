@model FastFood.Models.Product.ProductDetailModel

@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Areas/Guest/Views/Shared/_Layout.cshtml";
}

<!-- Product Detail Section -->
<section class="product-detail-section py-5">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb breadcrumb-custom">
                <li class="breadcrumb-item"><a asp-area="Guest" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-area="Guest" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>

        <div class="row g-5">
            <!-- Product Image -->
            <div class="col-lg-5">
                <div class="premium-image-container shadow-lg" style="padding-bottom: 100%;">
                    @{
                        var mainImgUrl = Model.ImageUrl;
                        if (!string.IsNullOrEmpty(mainImgUrl) && !mainImgUrl.StartsWith("/") && !mainImgUrl.StartsWith("http"))
                        {
                            mainImgUrl = "/images/" + mainImgUrl;
                        }
                    }
                    <img src="@(string.IsNullOrEmpty(mainImgUrl) ? "https://via.placeholder.com/600x600/DC2626/FFFFFF?text=" + Model.Name : mainImgUrl)"
                         alt="@Model.Name" class="premium-image-square" id="mainImage">
                    @if (Model.AverageRating >= 4.5)
                    {
                        <div class="floating-rating">
                            <i class="fas fa-star"></i>
                            <span>@Model.AverageRating.ToString("0.0")</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Product Info -->
            <div class="col-lg-7">
                <div class="product-detail-info">
                    <span class="product-category-badge">@Model.CategoryName</span>
                    <h1 class="product-detail-title">@Model.Name</h1>

                    <div class="product-meta">
                        @if (Model.AverageRating > 0)
                        {
                            <div class="rating-display">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fas fa-star @(i <= Model.AverageRating ? "filled" : "")"></i>
                                }
                                <span>(@Model.AverageRating.ToString("0.0"))</span>
                            </div>
                        }
                        <span class="separator">•</span>
                        <span class="comments-count">
                            <i class="fas fa-comments"></i> @Model.CommentCount đánh giá
                        </span>
                    </div>

                    <div class="product-price-section">
                        <span class="current-price">@Model.Price.ToString("N0")đ</span>
                    </div>

                   <p class="productdescription">@Model.Description</p>

                    <div class="product-actions">
                        <div class="quantity-selector">
                            <button type="button" class="qty-btn" onclick="decreaseQty()">
                                <i class="fas fa-minus"></i>
                            </button>
                            <input type="number" id="quantity" value="1" min="1" class="qty-input" readonly>
                            <button type="button" class="qty-btn" onclick="increaseQty()">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>

                        @if (Context.Session.GetInt32("UserId").HasValue)
                        {
                            <div class="d-flex gap-2 flex-grow-1">
                                <button class="btn btn-outline-primary btn-lg flex-fill" onclick="addToCart(@Model.Id, parseInt(document.getElementById('quantity').value))" style="border: 2px solid #6F4E37; color: #6F4E37; background: transparent;" onmouseover="this.style.background='#6F4E37'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='#6F4E37';">
                                    <i class="fas fa-cart-plus me-2"></i>Vào Giỏ
                                </button>
                                <button class="btn btn-primary btn-lg flex-fill" onclick="buyNow(@Model.Id, parseInt(document.getElementById('quantity').value), 'product')">
                                    <i class="fas fa-bolt me-2"></i>Mua Ngay
                                </button>
                            </div>
                        }
                        else
                        {
                            <a asp-area="Guest" asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-lg flex-grow-1">
                                <i class="fas fa-sign-in-alt me-2"></i>Đăng Nhập Để Mua
                            </a>
                        }
                    </div>

                    <div class="product-features">
                        <div class="feature-item">
                            <i class="fas fa-shipping-fast"></i>
                            <span>Giao hàng trước khi đá tan (30 phút)</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-leaf"></i>
                            <span>Nguyên liệu tươi mới mỗi ngày</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-coffee"></i>
                            <span>Pha chế bởi Barista chuyên nghiệp</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reviews Section -->
        <div class="reviews-section mt-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="section-title-premium mb-0">Đánh Giá <span class="text-gradient">Sản Phẩm</span></h3>
                @if (Context.Session.GetInt32("UserId").HasValue)
                {
                    <button class="btn btn-coffee" type="button" data-bs-toggle="collapse" data-bs-target="#reviewForm">
                        <i class="fas fa-edit me-2"></i>Viết đánh giá
                    </button>
                }
                else
                {
                    <a asp-area="Guest" asp-controller="Auth" asp-action="Login" class="btn btn-coffee">
                        <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập để đánh giá
                    </a>
                }
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4 mb-4" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-4 mb-4" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Add Review Form -->
            @if (Context.Session.GetInt32("UserId").HasValue)
            {
                <div class="collapse mb-4" id="reviewForm">
                    <div class="card card-body border-0 shadow-sm rounded-4" style="background: #FAF7F2; border: 1px solid #E8D8C8 !important;">
                        <form asp-area="Guest" asp-controller="Comment" asp-action="Create" method="post">
                            <input type="hidden" name="ProductId" value="@Model.Id" />
                            <div class="mb-3">
                                <label class="form-label fw-bold" style="color:#2A1C14;">Đánh giá của bạn</label>
                                <div class="star-rating-input">
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        <input type="radio" id="star@i" name="Rating" value="@i" required />
                                        <label for="star@i"><i class="fas fa-star"></i></label>
                                    }
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold" style="color:#2A1C14;">Nội dung</label>
                                <textarea name="Content" class="form-control" rows="3" required placeholder="Chia sẻ cảm nhận của bạn về sản phẩm..." style="border-radius:12px; border:1px solid #E8D8C8; outline:none;"></textarea>
                            </div>
                            <button type="submit" class="btn btn-coffee"><i class="fas fa-paper-plane me-2"></i>Gửi đánh giá</button>
                        </form>
                    </div>
                </div>
            }

            @{
                var currentUserId = Context.Session.GetInt32("UserId");
            }

            @if (Model.Comments != null && Model.Comments.Any())
            {
                <div class="row g-4">
                    @foreach (var comment in Model.Comments)
                    {
                        <div class="col-12">
                            <div class="review-card">
                                <div class="review-header">
                                    <div class="reviewer-info">
                                        <div class="reviewer-avatar">
                                            @comment.UserName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <h6 class="reviewer-name">@comment.UserName</h6>
                                            <div class="review-rating">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <i class="fas fa-star @(i <= comment.Rating ? "filled" : "")"></i>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <span class="review-date">@comment.CreatedAt.ToString("dd/MM/yyyy")</span>
                                </div>
                                <p class="review-content">@comment.Content</p>
                                
                                <div class="review-actions mt-3 d-flex align-items-center gap-3">
                                    <!-- Like Button -->
                                    <button class="btn-like" onclick="toggleLike(this)" title="Thích">
                                        <i class="far fa-heart"></i>
                                        <span class="like-count">0</span>
                                    </button>

                                    @if (currentUserId.HasValue)
                                    {
                                        <!-- Reply Button -->
                                        <button class="btn btn-link btn-sm text-coffee p-0 text-decoration-none fw-bold" 
                                                onclick="toggleReplyForm(@comment.Id)">
                                            <i class="fas fa-reply me-1"></i>Phản hồi
                                        </button>

                                        <!-- Delete Button (only for comment owner) -->
                                        @if (comment.UserId == currentUserId.Value)
                                        {
                                            <form asp-area="Guest" asp-controller="Comment" asp-action="Delete" method="post" class="d-inline"
                                                  onsubmit="return confirm('Bạn có chắc muốn xóa bình luận này?')">
                                                <input type="hidden" name="commentId" value="@comment.Id" />
                                                <input type="hidden" name="productId" value="@Model.Id" />
                                                <button type="submit" class="btn btn-link btn-sm text-danger p-0 text-decoration-none fw-bold">
                                                    <i class="fas fa-trash-alt me-1"></i>Xóa
                                                </button>
                                            </form>
                                        }
                                    }
                                    else
                                    {
                                        <a asp-area="Guest" asp-controller="Auth" asp-action="Login" class="btn btn-link btn-sm text-muted p-0 text-decoration-none">
                                            <i class="fas fa-reply me-1"></i>Đăng nhập để phản hồi
                                        </a>
                                    }
                                </div>

                                <!-- Reply Form -->
                                @if (currentUserId.HasValue)
                                {
                                    <div id="replyForm-@comment.Id" class="reply-form mt-3" style="display:none;">
                                        <form asp-area="Guest" asp-controller="Comment" asp-action="Create" method="post">
                                            <input type="hidden" name="ProductId" value="@Model.Id" />
                                            <input type="hidden" name="ParentId" value="@comment.Id" />
                                            <input type="hidden" name="Rating" value="5" /> <!-- Default rating for replies -->
                                            <div class="input-group">
                                                <input type="text" name="Content" class="form-control" placeholder="Viết phản hồi..." required style="border-radius: 12px 0 0 12px; border: 1px solid #E8D8C8;">
                                                <button class="btn btn-coffee" style="border-radius: 0 12px 12px 0;" type="submit">Gửi</button>
                                            </div>
                                        </form>
                                    </div>
                                }

                                <!-- Replies -->
                                @if (comment.Replies != null && comment.Replies.Any())
                                {
                                    <div class="replies-list mt-3 ms-5 ps-3 border-start border-2 border-coffee-light">
                                        @foreach (var reply in comment.Replies)
                                        {
                                            <div class="reply-item mb-3">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <div class="avatar-xs">@(reply.UserName?.Substring(0,1).ToUpper() ?? "?")</div>
                                                        <span class="fw-bold small">@reply.UserName</span>
                                                    </div>
                                                    <div class="d-flex align-items-center gap-2">
                                                        <small class="text-muted">@reply.CreatedAt.ToString("dd/MM/yyyy")</small>
                                                        @if (currentUserId.HasValue && reply.UserId == currentUserId.Value)
                                                        {
                                                            <form asp-area="Guest" asp-controller="Comment" asp-action="Delete" method="post" class="d-inline"
                                                                  onsubmit="return confirm('Xóa phản hồi này?')">
                                                                <input type="hidden" name="commentId" value="@reply.Id" />
                                                                <input type="hidden" name="productId" value="@Model.Id" />
                                                                <button type="submit" class="btn btn-link btn-sm text-danger p-0" style="font-size:0.75rem;">
                                                                    <i class="fas fa-trash-alt"></i>
                                                                </button>
                                                            </form>
                                                        }
                                                    </div>
                                                </div>
                                                <p class="mb-0 small text-gray-700 ms-4">@reply.Content</p>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-reviews">
                    <i class="fas fa-comment-slash fa-3x text-muted mb-3"></i>
                    <p>Chưa có đánh giá nào. Hãy là người đầu tiên!</p>
                </div>
            }
        </div>

        <!-- Related Products -->
        @if (Model.RelatedProducts != null && Model.RelatedProducts.Any())
        {
            <div class="related-products-section mt-5">
                <h3 class="section-title-premium mb-4">Sản Phẩm <span class="text-gradient">Tương Tự</span></h3>
                <div class="row g-4">
                    @foreach (var product in Model.RelatedProducts.Take(4))
                    {
                        <div class="col-lg-3 col-md-6">
                            <div class="product-card-premium">
                                <div class="premium-image-container">
                                    @{
                                        var relatedImgUrl = product.ImageUrl;
                                        if (!string.IsNullOrEmpty(relatedImgUrl) && !relatedImgUrl.StartsWith("/") && !relatedImgUrl.StartsWith("http"))
                                        {
                                            relatedImgUrl = "/images/" + relatedImgUrl;
                                        }
                                    }
                                    <img src="@(string.IsNullOrEmpty(relatedImgUrl) ? "https://via.placeholder.com/300x300" : relatedImgUrl)"
                                         class="premium-image-square"
                                         alt="@product.Name" />
                                    <div class="product-overlay">
                                        <a asp-area="Guest" asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id"
                                           class="btn btn-light btn-sm">
                                            <i class="fas fa-eye me-1"></i>Xem
                                        </a>
                                    </div>
                                </div>
                                <div class="product-content">
                                    <h5 class="product-name">@product.Name</h5>
                                    <div class="product-footer">
                                        <span class="product-price">@product.Price.ToString("N0")đ</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>

<style>
/* Product Detail */
.product-detail-image {
    position: relative;
    background: white;
    border-radius: 25px;
    padding: 2rem;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
}

.main-image {
    width: 100%;
    height: auto;
    border-radius: 20px;
}

.floating-rating {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: linear-gradient(135deg, #D4A853, #C4956A);
    color: #1A120A;
    padding: 0.75rem 1.25rem;
    border-radius: 50px;
    font-weight: 700;
    box-shadow: 0 10px 30px rgba(212, 168, 83, 0.4);
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.product-detail-info {
    background: white;
    padding: 2.5rem;
    border-radius: 25px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
}

.product-category-badge {
    background: #FDF6EE;
    color: #6F4E37;
    padding: 0.5rem 1.25rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    display: inline-block;
    margin-bottom: 1rem;
    border: 1px solid #E8D5C0;
}

.product-detail-title {
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
    color: var(--gray-900);
}

.product-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    color: var(--gray-600);
}

.rating-display {
    display: flex;
    align-items: center;
    gap: 0.25rem;
}

.rating-display i.filled {
    color: #F59E0B;
}

.rating-display i:not(.filled) {
    color: var(--gray-300);
}

.separator {
    color: var(--gray-400);
}

.product-price-section {
    background: var(--gray-100);
    padding: 1.5rem;
    border-radius: 15px;
    margin-bottom: 2rem;
}

.current-price {
    font-size: 2.5rem;
    font-weight: 900;
    color: #6F4E37;
}

.product-description {
    color: var(--gray-700);
    line-height: 1.8;
    margin-bottom: 2rem;
}

.product-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
}

.quantity-selector {
    display: flex;
    align-items: center;
    border: 2px solid var(--gray-300);
    border-radius: 12px;
    overflow: hidden;
}

.qty-btn {
    background: white;
    border: none;
    width: 45px;
    height: 45px;
    cursor: pointer;
    transition: all 0.3s ease;
    color: var(--gray-700);
}

.qty-btn:hover {
    background: #6F4E37;
    color: white;
}

.qty-input {
    width: 60px;
    border: none;
    text-align: center;
    font-weight: 700;
    font-size: 1.1rem;
}

.product-features {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--gray-200);
}

.feature-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--gray-700);
}

.feature-item i {
    color: #6F4E37;
    font-size: 1.25rem;
}

/* Reviews */
.review-card {
    background: #FAF7F2;
    padding: 2rem;
    border-radius: 20px;
    border: 2px solid #F0E8DF;
    transition: all 0.3s ease;
}

.review-card:hover {
    border-color: #6F4E37;
    box-shadow: 0 10px 30px rgba(111, 78, 55, 0.1);
    transform: translateY(-2px);
}

.review-header {
    display: flex;
    justify-content: space-between;
    align-items: start;
    margin-bottom: 1.25rem;
}

.reviewer-info {
    display: flex;
    gap: 1rem;
    align-items: center;
}

.reviewer-avatar {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #6F4E37, #C4956A);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    box-shadow: 0 4px 10px rgba(111, 78, 55, 0.2);
}

.reviewer-name {
    margin-bottom: 0.25rem;
    font-weight: 700;
    color: #2A1C14;
    font-size: 1.05rem;
}

.review-rating i.filled { color: #D4A853; }
.review-rating i:not(.filled) { color: #E8D8C8; }

.review-date {
    color: #9C8B7E;
    font-size: 0.85rem;
    font-weight: 500;
}

.review-content {
    color: #4A3B32;
    line-height: 1.7;
    margin: 0;
    font-size: 0.95rem;
}

.empty-reviews {
    text-align: center;
    padding: 3rem;
    color: #9C8B7E;
}

.border-coffee-light { border-color: #E8D8C8 !important; }

@@media (max-width: 992px) {
    .product-detail-title { font-size: 2rem; }
    .product-actions { flex-direction: column; }
}

/* Star Rating Input */
.star-rating-input {
    display: flex;
    flex-direction: row-reverse;
    justify-content: flex-end;
    gap: 0.5rem;
}

.star-rating-input input { display: none; }

.star-rating-input label {
    font-size: 1.75rem;
    color: #E8D8C8;
    cursor: pointer;
    transition: color 0.2s, transform 0.2s;
}

.star-rating-input input:checked ~ label,
.star-rating-input label:hover,
.star-rating-input label:hover ~ label {
    color: #D4A853;
}
.star-rating-input label:hover { transform: scale(1.1); }

.avatar-xs {
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, #6F4E37, #C4956A);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
}

/* Like Button */
.btn-like {
    background: none;
    border: 1.5px solid #E8D8C8;
    border-radius: 20px;
    padding: 4px 12px;
    cursor: pointer;
    color: #9C8B7E;
    font-size: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: all 0.2s ease;
}
.btn-like:hover {
    border-color: #e05c7a;
    color: #e05c7a;
    background: #fff5f7;
}
.btn-like.liked {
    border-color: #e05c7a;
    color: #e05c7a;
    background: #fff5f7;
}
.btn-like.liked i { font-weight: 900; }
</style>

<script>
function increaseQty() {
    const input = document.getElementById('quantity');
    input.value = parseInt(input.value) + 1;
}

function decreaseQty() {
    const input = document.getElementById('quantity');
    if (parseInt(input.value) > 1) {
        input.value = parseInt(input.value) - 1;
    }
}

// Local function removed - now using global addToCart from _Layout.cshtml

function toggleReplyForm(commentId) {
    const form = document.getElementById(`replyForm-${commentId}`);
    if (form) form.style.display = form.style.display === 'none' ? 'block' : 'none';
}

function toggleLike(btn) {
    const isLiked = btn.classList.contains('liked');
    const countEl = btn.querySelector('.like-count');
    const icon = btn.querySelector('i');
    
    if (isLiked) {
        btn.classList.remove('liked');
        icon.classList.replace('fas', 'far');
        countEl.textContent = Math.max(0, parseInt(countEl.textContent) - 1);
    } else {
        btn.classList.add('liked');
        icon.classList.replace('far', 'fas');
        countEl.textContent = parseInt(countEl.textContent) + 1;
    }
}
</script>
