<script>
// Load notifications on page load
document.addEventListener('DOMContentLoaded', function() {
    loadNotifications();
    loadCartCount();
    
    // Refresh notifications every 30 seconds
    setInterval(loadNotifications, 30000);
});

function loadNotifications() {
    var userId = '@Context.Session.GetInt32("UserId")';
    if (!userId || userId === '') {
        // For guests, show general notifications (userId = null)
        userId = 0;
    }
    
    fetch('/api/notification/user/' + userId)
        .then(response => {
            if (!response.ok) throw new Error('API 404');
            return response.json();
        })
        .then(data => {
            if (data && data.length > 0) {
                updateNotificationList(data);
                updateNotificationCount(data.filter(n => !n.isRead).length);
            }
        })
        .catch(err => console.log('Notification API not available yet.'));
}

function updateNotificationList(notifications) {
    var listEl = document.getElementById('notificationList');
    if (!listEl) return;
    
    if (notifications.length === 0) {
        listEl.innerHTML = '<div class="text-center p-3 text-muted"><i class="fas fa-bell-slash"></i> Không có thông báo mới</div>';
        return;
    }
    
    var html = '';
    notifications.forEach(function(notif) {
        var icon = 'fa-bell';
        if (notif.type === 'NewProduct') icon = 'fa-hamburger';
        else if (notif.type === 'NewCombo') icon = 'fa-box';
        else if (notif.type === 'NewVoucher') icon = 'fa-ticket-alt';
        else if (notif.type === 'VoucherExpiring') icon = 'fa-clock';
        
        html += '<li class="notification-item' + (!notif.isRead ? ' unread' : '') + '" onclick="markAsRead(' + notif.id + ', \'' + (notif.url || '#') + '\')">';
        html += '  <div class="d-flex align-items-start">';
        html += '    <div class="notification-icon"><i class="fas ' + icon + '"></i></div>';
        html += '    <div class="notification-content">';
        html += '      <div class="notification-title">' + notif.title + '</div>';
        html += '      <div class="notification-message">' + notif.message + '</div>';
        html += '      <div class="notification-time">' + notif.createdAt + '</div>';
        html += '    </div>';
        html += '  </div>';
        html += '</li>';
    });
    
    listEl.innerHTML = html;
}

function updateNotificationCount(count) {
    var badge = document.getElementById('notificationCount');
    if (badge) {
        if (count > 0) {
            badge.textContent = count > 99 ? '99+' : count;
            badge.style.display = 'flex';
        } else {
            badge.style.display = 'none';
        }
    }
}

function markAsRead(notificationId, url) {
    fetch('/api/notification/mark-read/' + notificationId, { method: 'POST' })
        .then(() => {
            if (url && url !== '#') {
                window.location.href = url;
            } else {
                loadNotifications();
            }
        });
}

function loadCartCount() {
    fetch('/Guest/Cart/GetCart')
        .then(response => {
            if (!response.ok) throw new Error('Cart API 404');
            return response.json();
        })
        .then(data => {
            if (data && data.count !== undefined) {
                updateCartBadge(data.count);
            }
        })
        .catch(err => console.log('Cart count sync skip.'));
}

function updateCartBadge(count) {
    var badges = document.querySelectorAll('.cart-badge');
    badges.forEach(function(badge) {
        if (count > 0) {
            badge.textContent = count;
            badge.style.display = 'flex';
        } else {
            badge.style.display = 'none';
        }
    });
}

// Add to Cart function (to be called from product cards)
function addToCart(id, quantity, type) {
    quantity = quantity || 1;
    type = type || 'product';
    
    var url = type === 'combo' ? '/Guest/Cart/AddComboToCart' : '/Guest/Cart/AddToCart';
    var payload = type === 'combo' ? { comboId: id, quantity: quantity } : { productId: id, quantity: quantity };
    
    fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Show success notification
            showNotification(data.message, 'success');
            updateCartBadge(data.cartCount);
        } else {
            showNotification(data.message, 'error');
        }
    })
    .catch(err => {
        showNotification('Có lỗi xảy ra', 'error');
    });
}

function buyNow(id, quantity, type) {
    quantity = quantity || 1;
    type = type || 'product';
    
    var url = type === 'combo' ? '/Guest/Cart/AddComboToCart' : '/Guest/Cart/AddToCart';
    var payload = type === 'combo' ? { comboId: id, quantity: quantity } : { productId: id, quantity: quantity };
    
    fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            window.location.href = '/Guest/Checkout/Index';
        } else {
            if (data.message && data.message.indexOf('đăng nhập') >= 0) {
                window.location.href = '/Guest/Auth/Login';
            } else {
                showNotification(data.message, 'error');
            }
        }
    })
    .catch(err => {
        showNotification('Có lỗi xảy ra', 'error');
    });
}

function showNotification(message, type) {
    // Create toast notification
    var toast = document.createElement('div');
    toast.className = 'toast-notification toast-' + type;
    toast.innerHTML = '<i class="fas fa-' + (type === 'success' ? 'check-circle' : 'exclamation-circle') + '"></i> ' + message;
    toast.style.cssText = 'position: fixed; top: 100px; right: 20px; background: ' + (type === 'success' ? '#10b981' : '#ef4444') + '; color: white; padding: 1rem 1.5rem; border-radius: 10px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); z-index: 9999; animation: slideIn 0.3s ease;';
    
    document.body.appendChild(toast);
    
    setTimeout(function() {
        toast.style.animation = 'slideOut 0.3s ease';
        setTimeout(function() { toast.remove(); }, 300);
    }, 3000);
}
</script>

<style>
@@keyframes slideIn {
    from { transform: translateX(400px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
}

@@keyframes slideOut {
    from { transform: translateX(0); opacity: 1; }
    to { transform: translateX(400px); opacity: 0; }
}
</style>

