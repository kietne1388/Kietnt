@{
    ViewData["Title"] = "Thanh Toán Chuyển Khoản";
    var orderId = ViewBag.OrderId;
}

<section class="page-header-premium">
    <div class="container">
        <h1 class="page-title">
            <i class="fas fa-university me-3"></i>Chuyển Khoản Ngân Hàng
        </h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb-premium">
                <li><a asp-area="Guest" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="active">Thanh toán chuyển khoản</li>
            </ol>
        </nav>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="payment-card text-center">
                    <div class="success-icon mb-4">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h3 class="mb-4">Đặt Hàng Thành Công!</h3>
                    <p class="text-muted mb-4">Mã đơn hàng: #@orderId</p>
                    <p>Vui lòng quét mã QR bên dưới để thanh toán</p>
                    
                    <div class="qr-container mb-4">
                        <img src="/images/payment/bank-qr-placeholder.jpg" alt="Bank QR Code" class="img-fluid qr-code">
                    </div>

                    <div class="bank-info text-start">
                        <div class="info-row">
                            <span>Ngân hàng:</span>
                            <strong>MB Bank</strong>
                        </div>
                        <div class="info-row">
                            <span>Chủ tài khoản:</span>
                            <strong>NGUYEN VAN KIET</strong>
                        </div>
                        <div class="info-row">
                            <span>Số tài khoản:</span>
                            <strong class="text-primary copy-text" onclick="copyToClipboard('0334816665')">
                                0334816665 <i class="fas fa-copy ms-2"></i>
                            </strong>
                        </div>
                        <div class="info-row">
                            <span>Nội dung:</span>
                            <strong>THANHTOAN DH @orderId</strong>
                        </div>
                    </div>

                    <div class="mt-4">
                        <a asp-action="OrderSuccess" class="btn btn-primary btn-lg w-100">
                            <i class="fas fa-check me-2"></i>Đã Hoàn Thành Thanh Toán
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                            Để sau (Về trang chủ)
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.payment-card {
    background: white;
    border-radius: 20px;
    padding: 3rem 2rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
}

.success-icon {
    font-size: 4rem;
    color: var(--success);
}

.qr-container {
    border: 2px dashed var(--gray-300);
    padding: 1rem;
    border-radius: 15px;
    display: inline-block;
    background: white;
}

.qr-code {
    max-width: 250px;
    border-radius: 10px;
}

.bank-info {
    background: var(--gray-50);
    padding: 1.5rem;
    border-radius: 15px;
    margin-top: 2rem;
}

.info-row {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--gray-200);
}

.info-row:last-child {
    border-bottom: none;
}

.copy-text {
    cursor: pointer;
    transition: color 0.3s;
}

.copy-text:hover {
    color: var(--primary-red) !important;
}
</style>

<script>
function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(function() {
        alert('Đã sao chép số tài khoản: ' + text);
    }, function(err) {
        console.error('Could not copy text: ', err);
    });
}
</script>
