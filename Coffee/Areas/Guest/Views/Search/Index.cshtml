@model List<FastFood.Models.Product.ProductModel>

@{
    ViewData["Title"] = "Kết Quả Tìm Kiếm";
    Layout = "~/Areas/Guest/Views/Shared/_Layout.cshtml";
    var query = Context.Request.Query["q"].ToString();
}

<section class="page-header-compact">
    <div class="container">
        <h1 class="page-title-compact">Kết Quả <span class="text-gradient">Tìm Kiếm</span></h1>
        <p class="mb-0 text-white-50">Tìm thấy @(Model?.Count ?? 0) kết quả cho "@query"</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        @if (Model != null && Model.Any())
        {
            <div class="row g-4">
                @foreach (var product in Model)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="product-card-premium">
                            <div class="product-image-wrapper">
                                <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "https://via.placeholder.com/300" : product.ImageUrl)"
                                     class="product-image"
                                     alt="@product.Name" />
                                <div class="product-overlay">
                                    <a asp-area="Guest" asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id"
                                       class="btn btn-light btn-sm">
                                        <i class="fas fa-eye me-1"></i>Xem
                                    </a>
                                </div>
                            </div>
                            <div class="product-content">
                                <div class="product-category">@product.CategoryName</div>
                                <h5 class="product-name">@product.Name</h5>
                                <div class="product-footer">
                                    <span class="product-price">@product.Price.ToString("N0")đ</span>
                                    @if (product.AverageRating > 0)
                                    {
                                        <div class="product-rating">
                                            <i class="fas fa-star"></i>
                                            <span>@product.AverageRating.ToString("0.0")</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state-full">
                <i class="fas fa-search fa-5x text-muted mb-4"></i>
                <h4>Không tìm thấy kết quả</h4>
                <p class="text-muted mb-4">Thử tìm kiếm với từ khóa khác</p>
                <a asp-area="Guest" asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">
                    <i class="fas fa-utensils me-2"></i>Xem Tất Cả Sản Phẩm
                </a>
            </div>
        }
    </div>
</section>
