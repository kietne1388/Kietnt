@model List<FastFood.Models.Product.ProductModel>

@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Areas/Guest/Views/Shared/_Layout.cshtml";
}

<!-- ===== HERO SECTION ===== -->
<section class="hero-coffee">
    <div class="hero-bg-anim"></div>
    <div class="container">
        <div class="row align-items-center min-vh-85">
            <div class="col-lg-6 fade-in" style="animation-delay:0.1s">
                <span class="hero-badge"> Khai trương – Giảm 20% tất cả combo</span>
                <h1 class="hero-headline">
                    Mỗi Tách Cà Phê<br/>
                    <span class="hero-highlight">Là Một Câu Chuyện</span>
                </h1>
                <p class="hero-sub">
                    Hạt cà phê Arabica thượng hạng, rang bởi nghệ nhân — mang đến hương vị tinh tế
                    và không gian thư giãn đích thực giữa lòng thành phố.
                </p>
                <div class="hero-stats">
                    <div class="stat-pill">
                        <span class="stat-num">18+</span>
                        <span class="stat-label">Thức uống</span>
                    </div>
                    <div class="stat-pill">
                        <span class="stat-num">5★</span>
                        <span class="stat-label">Chất lượng</span>
                    </div>
                    <div class="stat-pill">
                        <span class="stat-num">3K+</span>
                        <span class="stat-label">Khách yêu mến</span>
                    </div>
                </div>
                <div class="hero-cta">
                    <a asp-area="Guest" asp-controller="Product" asp-action="Index" class="btn-coffee-primary">
                        <i class="fas fa-mug-hot me-2"></i>Khám phá thực đơn
                    </a>
                    <a asp-area="Guest" asp-controller="Combo" asp-action="Index" class="btn-coffee-outline">
                        <i class="fas fa-box-open me-2"></i>Xem combo ưu đãi
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center fade-in" style="animation-delay:0.3s">
                <div class="hero-visual">
                    <div class="hero-circle-bg"></div>
                    <div class="floating-badge badge-top">
                        <i class="fas fa-award"></i>
                        <span>Arabica thượng hạng</span>
                    </div>
                    <div class="floating-badge badge-left">
                        <i class="fas fa-leaf"></i>
                        <span>Nguyên liệu sạch</span>
                    </div>
                    <div class="floating-badge badge-bottom">
                        <i class="fas fa-shipping-fast"></i>
                        <span>Giao tận nơi</span>
                    </div>
                    <img src="~/images/products/Coffee.jpg"
                         alt="CaféLux"
                         class="hero-img"
                         onerror="this.src='https://placehold.co/500x500/6F4E37/FDF6EE?text=CaféLux'">
                </div>
            </div>
        </div>
    </div>
    <div class="hero-wave">
        <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,40 Q360,80 720,40 T1440,40 V80 H0 V40 Z" fill="#FAF7F4"/>
        </svg>
    </div>
</section>

<!-- ===== WHY CHOOSE US ===== -->
<section class="features-coffee py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="feat-card">
                    <div class="feat-icon">
                        <i class="fas fa-coffee"></i>
                    </div>
                    <h5>Hạt Arabica Premium</h5>
                    <p>Nhập khẩu từ Ethiopia & Colombia, rang fresh mỗi ngày bởi nghệ nhân</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="feat-card">
                    <div class="feat-icon">
                        <i class="fas fa-leaf"></i>
                    </div>
                    <h5>Nguyên Liệu Hữu Cơ</h5>
                    <p>Sữa tươi nguyên chất, trái cây tươi theo mùa, topping handmade mỗi ngày</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="feat-card">
                    <div class="feat-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <h5>Barista Chuyên Nghiệp</h5>
                    <p>Đội ngũ barista được đào tạo bài bản, tâm huyết với từng tách cà phê</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="feat-card">
                    <div class="feat-icon">
                        <i class="fas fa-shipping-fast"></i>
                    </div>
                    <h5>Giao Hàng Tận Nơi</h5>
                    <p>Đặt online, nhận thức uống nóng hổi tại nhà trong vòng 30 phút</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== MENU CATEGORIES ===== -->
<section class="categories-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-badge">🍵 Danh mục đồ uống</span>
            <h2 class="section-heading">Khám Phá <span class="text-brown">Thực Đơn</span></h2>
            <p class="section-sub">Từ cà phê đậm đà đến trà thơm, sinh tố mát lạnh – cho mỗi khoảnh khắc trong ngày</p>
        </div>
        <div class="row g-3 justify-content-center">
            <div class="col-auto">
                <a asp-area="Guest" asp-controller="Product" asp-action="Index" asp-route-categoryId="1" class="cat-pill">
                    <i class="fas fa-coffee"></i> Cà phê
                </a>
            </div>
            <div class="col-auto">
                <a asp-area="Guest" asp-controller="Product" asp-action="Index" asp-route-categoryId="2" class="cat-pill">
                    <i class="fas fa-leaf"></i> Trà
                </a>
            </div>
            <div class="col-auto">
                <a asp-area="Guest" asp-controller="Product" asp-action="Index" asp-route-categoryId="3" class="cat-pill">
                    <i class="fas fa-blender"></i> Sinh tố & Đá xay
                </a>
            </div>
            <div class="col-auto">
                <a asp-area="Guest" asp-controller="Product" asp-action="Index" asp-route-categoryId="4" class="cat-pill">
                    <i class="fas fa-glass-whiskey"></i> Đồ uống đặc biệt
                </a>
            </div>
            <div class="col-auto">
                <a asp-area="Guest" asp-controller="Product" asp-action="Index" asp-route-categoryId="5" class="cat-pill">
                    <i class="fas fa-cookie"></i> Bánh & Snack
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ===== FEATURED DRINKS ===== -->
<section class="drinks-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-badge">✨ Được yêu thích nhất</span>
            <h2 class="section-heading">Đồ Uống <span class="text-brown">Nổi Bật</span></h2>
            <p class="section-sub">Những thức uống được khách hàng đặt nhiều nhất tại CaféLux</p>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="row g-4">
                @foreach (var product in Model.Take(8))
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="drink-card">
                            @if (product.AverageRating >= 4.5)
                            {
                                <div class="drink-hot-badge">
                                    <i class="fas fa-fire-alt"></i> Hot
                                </div>
                            }
                            <div class="drink-img-wrap">
                                @{
                                    var homeImgUrl = product.ImageUrl;
                                    if (!string.IsNullOrEmpty(homeImgUrl) && !homeImgUrl.StartsWith("/") && !homeImgUrl.StartsWith("http"))
                                    {
                                        homeImgUrl = "/images/" + homeImgUrl;
                                    }
                                }
                                <img src="@(string.IsNullOrEmpty(homeImgUrl) ? "/images/placeholder-coffee.jpg" : homeImgUrl)"
                                     alt="@product.Name"
                                     onerror="this.src='https://placehold.co/300x300/6F4E37/FDF6EE?text=☕'"  />
                                <div class="drink-overlay">
                                    <a asp-area="Guest" asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id"
                                       class="overlay-btn">
                                        <i class="fas fa-eye me-1"></i> Xem chi tiết
                                    </a>
                                </div>
                            </div>
                            <div class="drink-body">
                                <span class="drink-cat">@product.CategoryName</span>
                                <h5 class="drink-name">@product.Name</h5>
                                <p class="drink-desc">
                                    @(product.Description?.Length > 65 ? product.Description.Substring(0, 65) + "…" : product.Description)
                                </p>
                                <div class="drink-foot">
                                    <span class="drink-price">@product.Price.ToString("N0")đ</span>
                                    @if (product.AverageRating > 0)
                                    {
                                        <span class="drink-rating">
                                            <i class="fas fa-star"></i> @product.AverageRating.ToString("0.0")
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-5">
                <a asp-area="Guest" asp-controller="Product" asp-action="Index" class="btn-coffee-primary">
                    <i class="fas fa-th me-2"></i>Xem toàn bộ thực đơn
                </a>
            </div>
        }
        else
        {
            <div class="empty-coffee">
                <i class="fas fa-mug-hot fa-4x"></i>
                <h4>Chưa có thức uống nào</h4>
                <p>Vui lòng quay lại sau nhé!</p>
            </div>
        }
    </div>
</section>

@if (!Context.Session.GetInt32("UserId").HasValue)
{
    <!-- ===== CTA BANNER ===== -->
    <section class="cta-coffee py-5">
        <div class="container">
            <div class="cta-inner">
                <div class="cta-decor"></div>
                <div class="row align-items-center">
                    <div class="col-lg-7">
                        <span class="section-badge mb-3 d-inline-block">🎁 Ưu đãi hội viên</span>
                        <h2 class="cta-title">Đăng Ký Thành Viên –<br/>Nhận Ưu Đãi Độc Quyền</h2>
                        <p class="cta-desc">Tích điểm mỗi đơn hàng, đổi voucher giảm giá, và nhận ưu đãi sinh nhật đặc biệt từ Tâm Coffee.</p>
                    </div>
                    <div class="col-lg-5 text-lg-end mt-4 mt-lg-0">
                        <a asp-area="Guest" asp-controller="Auth" asp-action="Register" class="btn-coffee-light me-3">
                            <i class="fas fa-user-plus me-2"></i>Đăng ký ngay
                        </a>
                        <a asp-area="Guest" asp-controller="Combo" asp-action="Index" class="btn-coffee-ghost">
                            <i class="fas fa-box-open me-2"></i>Xem combo
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<style>
/* ===== HERO ===== */
.hero-coffee {
    position: relative;
    background: linear-gradient(135deg, #2C1A0E 0%, #6F4E37 65%, #C4956A 100%);
    padding: 100px 0 140px;
    overflow: hidden;
    color: white;
}
.hero-bg-anim {
    position: absolute; inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at 15% 60%, rgba(212,168,83,0.12) 0%, transparent 55%),
                radial-gradient(circle at 85% 20%, rgba(196,149,106,0.1) 0%, transparent 50%);
    animation: breathe 5s ease-in-out infinite;
}
@@keyframes breathe { 0%,100%{opacity:.7} 50%{opacity:1} }

.min-vh-85 { min-height: 85vh; }

.hero-badge {
    display: inline-block;
    background: rgba(212,168,83,0.25);
    border: 1px solid rgba(212,168,83,0.5);
    color: #F0C97A;
    padding: .45rem 1.25rem;
    border-radius: 50px;
    font-size: .9rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(8px);
}
.hero-headline {
    font-family: 'Playfair Display', Georgia, serif !important;
    font-size: 3.4rem;
    font-weight: 800;
    line-height: 1.12;
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 20px rgba(0,0,0,.2);
}
.hero-highlight {
    background: linear-gradient(135deg, #F0C97A, #D4A853);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}
.hero-sub {
    font-size: 1.15rem;
    opacity: .92;
    line-height: 1.8;
    max-width: 520px;
    margin-bottom: 2rem;
}
.hero-stats {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.25rem;
}
.stat-pill {
    background: rgba(255,255,255,.1);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 15px;
    padding: .75rem 1.25rem;
    text-align: center;
}
.stat-num { display:block; font-size:1.5rem; font-weight:800; color:#F0C97A; }
.stat-label { font-size:.78rem; opacity:.85; }
.hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

/* Hero visual */
.hero-visual { position: relative; display: inline-block; max-width: 480px; }
.hero-circle-bg {
    position: absolute;
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(212,168,83,.15), transparent 70%);
    border-radius: 50%;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
}
.hero-img {
    width: 100%; max-width: 440px;
    filter: drop-shadow(0 30px 60px rgba(0,0,0,.35));
    animation: floatImg 4s ease-in-out infinite;
    position: relative; z-index: 1;
}
@@keyframes floatImg { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-16px)} }

.floating-badge {
    position: absolute;
    background: white;
    border-radius: 14px;
    padding: .65rem 1.1rem;
    display: flex; align-items: center; gap: .6rem;
    font-size: .82rem; font-weight: 700;
    color: #3E2D1E;
    box-shadow: 0 8px 25px rgba(0,0,0,.18);
    z-index: 2;
    animation: floatBadge 3s ease-in-out infinite;
    white-space: nowrap;
}
.floating-badge i { color: #6F4E37; font-size: 1rem; }
.badge-top    { top: 5%;  right: -5%; animation-delay: 0s; }
.badge-left   { top: 42%; left: -8%; animation-delay: 1s; }
.badge-bottom { bottom: 8%; right: 5%; animation-delay: 2s; }
@@keyframes floatBadge { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }

.hero-wave { position:absolute; bottom:-1px; left:0; width:100%; }
.hero-wave svg { width:100%; height:80px; }

/* ===== BUTTONS ===== */
.btn-coffee-primary {
    display: inline-flex; align-items: center;
    background: linear-gradient(135deg, #D4A853, #C4956A);
    color: #2C1A0E;
    padding: .85rem 2rem;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    transition: all .3s ease;
    box-shadow: 0 8px 25px rgba(212,168,83,.4);
    font-family: 'Lato', sans-serif;
    border: none; cursor: pointer;
}
.btn-coffee-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(212,168,83,.6);
    color: #1A120A;
    filter: brightness(1.1);
}
.btn-coffee-outline {
    display: inline-flex; align-items: center;
    background: rgba(255,255,255,.1);
    color: white;
    padding: .85rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid rgba(255,255,255,.4);
    transition: all .3s ease;
    backdrop-filter: blur(6px);
}
.btn-coffee-outline:hover {
    background: rgba(255,255,255,.2);
    color: white;
    transform: translateY(-3px);
}
.btn-coffee-light {
    display: inline-flex; align-items: center;
    background: white;
    color: #6F4E37;
    padding: .85rem 2rem;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    transition: all .3s ease;
    box-shadow: 0 8px 25px rgba(0,0,0,.15);
}
.btn-coffee-light:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(0,0,0,.2);
    color: #4A2E1A;
}
.btn-coffee-ghost {
    display: inline-flex; align-items: center;
    background: transparent;
    color: white;
    padding: .85rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid rgba(255,255,255,.5);
    transition: all .3s ease;
}
.btn-coffee-ghost:hover {
    background: rgba(255,255,255,.1);
    color: white;
    transform: translateY(-3px);
}

/* ===== FEATURES ===== */
.features-coffee { background: #FAF7F4; }
.feat-card {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    text-align: center;
    border: 2px solid transparent;
    transition: all .4s ease;
    height: 100%;
    box-shadow: 0 4px 15px rgba(111,78,55,.06);
}
.feat-card:hover {
    transform: translateY(-8px);
    border-color: #C4956A;
    box-shadow: 0 20px 40px rgba(111,78,55,.15);
}
.feat-icon {
    width: 72px; height: 72px;
    background: linear-gradient(135deg, #FDF6EE, #F5E6D3);
    border-radius: 18px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.25rem;
    transition: all .4s ease;
}
.feat-icon i { font-size: 1.75rem; color: #6F4E37; transition: all .4s ease; }
.feat-card:hover .feat-icon { background: linear-gradient(135deg, #6F4E37, #4A2E1A); }
.feat-card:hover .feat-icon i { color: white; transform: scale(1.1); }
.feat-card h5 { font-weight: 700; color: #2C1A0E; margin-bottom: .6rem; font-size: 1.05rem; }
.feat-card p  { color: #7D5E42; font-size: .92rem; line-height: 1.65; margin: 0; }

/* ===== COMMON SECTION STYLES ===== */
.section-badge {
    display: inline-block;
    background: linear-gradient(135deg, #FDF6EE, #F5E6D3);
    color: #6F4E37;
    border: 1px solid #E8D5C0;
    padding: .45rem 1.25rem;
    border-radius: 50px;
    font-size: .88rem;
    font-weight: 700;
    margin-bottom: .85rem;
}
.section-heading {
    font-family: 'Playfair Display', Georgia, serif !important;
    font-size: 2.4rem;
    font-weight: 800;
    color: #1A120A;
    margin-bottom: .75rem;
}
.section-sub {
    font-size: 1.05rem;
    color: #7D5E42;
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.7;
}
.text-brown {
    color: #6F4E37;
}

/* ===== CATEGORY PILLS ===== */
.categories-section { background: white; }
.cat-pill {
    display: inline-flex; align-items: center; gap: .5rem;
    background: #FAF7F4;
    color: #5C4230;
    border: 2px solid #E8D5C0;
    padding: .6rem 1.4rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: .9rem;
    text-decoration: none;
    transition: all .3s ease;
}
.cat-pill:hover, .cat-pill.active {
    background: linear-gradient(135deg, #6F4E37, #4A2E1A);
    color: white;
    border-color: transparent;
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(111,78,55,.3);
}
.cat-pill i { font-size: .95rem; }

/* ===== DRINK CARDS ===== */
.drinks-section { background: #FAF7F4; }
.drink-card {
    background: white;
    border-radius: 22px;
    overflow: hidden;
    border: 2px solid #E8D5C0;
    transition: all .4s cubic-bezier(.4,0,.2,1);
    position: relative;
    height: 100%;
}
.drink-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 25px 50px rgba(111,78,55,.18);
    border-color: #C4956A;
}
.drink-hot-badge {
    position: absolute; top: 12px; right: 12px;
    background: linear-gradient(135deg, #D4A853, #C4956A);
    color: #2C1A0E;
    padding: .35rem .85rem;
    border-radius: 50px;
    font-size: .78rem;
    font-weight: 800;
    z-index: 10;
    box-shadow: 0 4px 12px rgba(212,168,83,.4);
}
.drink-img-wrap {
    position: relative;
    padding-bottom: 85%;
    overflow: hidden;
    background: #F5EDE3;
}
.drink-img-wrap img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
}
.drink-card:hover .drink-img-wrap img { transform: scale(1.08); }
.drink-overlay {
    position: absolute; inset: 0;
    background: rgba(74,46,26,.85);
    display: flex; align-items: center; justify-content: center;
    opacity: 0;
    transition: opacity .4s ease;
}
.drink-card:hover .drink-overlay { opacity: 1; }
.overlay-btn {
    background: linear-gradient(135deg, #D4A853, #C4956A);
    color: #2C1A0E;
    padding: .65rem 1.5rem;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    font-size: .9rem;
    transition: all .3s;
}
.overlay-btn:hover { transform: scale(1.05); color: #1A120A; }

.drink-body { padding: 1.25rem; }
.drink-cat {
    background: #F5EDE3;
    color: #5C4230;
    padding: .2rem .75rem;
    border-radius: 50px;
    font-size: .75rem;
    font-weight: 700;
    display: inline-block;
    margin-bottom: .65rem;
}
.drink-name {
    font-size: 1.05rem; font-weight: 800;
    color: #1A120A;
    margin-bottom: .4rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.drink-desc {
    font-size: .85rem;
    color: #7D5E42;
    line-height: 1.55;
    margin-bottom: .75rem;
    min-height: 40px;
}
.drink-foot {
    display: flex; justify-content: space-between; align-items: center;
    border-top: 1px solid #E8D5C0;
    padding-top: .75rem;
}
.drink-price {
    font-size: 1.3rem; font-weight: 900;
