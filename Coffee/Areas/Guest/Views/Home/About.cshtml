@{
    ViewData["Title"] = "Về Chúng Tôi";
    Layout = "~/Areas/Guest/Views/Shared/_Layout.cshtml";
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <h1 class="page-title">Về <span class="text-gradient">CoffeeLux</span></h1>
        <p class="page-subtitle">Câu chuyện của chúng tôi</p>
    </div>
</section>

<!-- Story Section -->
<section class="story-section py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="section-label">Hành Trình</span>
                <h2 class="section-title-premium">Câu Chuyện <span class="text-gradient">Của Chúng Tôi</span></h2>
                <p class="lead">Từ một quán nhỏ đến chuỗi thương hiệu cà phê hàng đầu Việt Nam</p>
                <p>Được thành lập vào năm 2020, CoffeeLux bắt đầu với một sứ mệnh đơn giản: mang đến những tách cà phê ngon, chất lượng và không gian thư giãn cho mọi người. Sau hơn 4 năm phát triển, chúng tôi tự hào đã phục vụ hơn 500,000 khách hàng với hơn 20 chi nhánh trên toàn quốc.</p>
                <p>Chìa khóa thành công của chúng tôi nằm ở cam kết sử dụng hạt cà phê cao cấp nhất, quy trình rang xay hiện đại và đội ngũ barista tận tâm. Mỗi ly cà phê tại CoffeeLux đều được pha chế với tình yêu và sự chú tâm đến từng chi tiết nhỏ nhất.</p>
                <div class="stats-grid mt-4">
                    <div class="stat-card">
                        <h3>50+</h3>
                        <p>Chi nhánh</p>
                    </div>
                    <div class="stat-card">
                        <h3>1M+</h3>
                        <p>Khách hàng</p>
                    </div>
                    <div class="stat-card">
                        <h3>500+</h3>
                        <p>Nhân viên</p>
                    </div>
                    <div class="stat-card">
                        <h3>100+</h3>
                        <p>Thức uống</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="story-image-grid">
                    <div class="story-image story-img-1">
                        <img src="https://images.unsplash.com/photo-1497935586351-b67a49e012bf?w=500&h=600&fit=crop" alt="Coffee Shop">
                    </div>
                    <div class="story-image story-img-2">
                        <img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=500&h=300&fit=crop" alt="Coffee Art">
                    </div>
                    <div class="story-image story-img-3">
                        <img src="https://images.unsplash.com/photo-1511920170033-f8396924c348?w=500&h=300&fit=crop" alt="Barista">
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Timeline Section -->
<section class="timeline-section py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-label">Dấu Mốc</span>
            <h2 class="section-title-premium">Hành Trình <span class="text-gradient">Phát Triển</span></h2>
        </div>
        <div class="timeline">
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-year">2015</span>
                    <h4>Khởi Đầu</h4>
                    <p>Khai trương cửa hàng đầu tiên tại TP.HCM với 10 nhân viên và 20 loại thức uống.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-year">2017</span>
                    <h4>Mở Rộng</h4>
                    <p>Mở thêm 10 chi nhánh tại các quận trung tâm, đạt 100,000 khách hàng.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-year">2019</span>
                    <h4>Ra Mắt App</h4>
                    <p>Triển khai ứng dụng đặt hàng online, tăng trải nghiệm khách hàng 300%.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-year">2021</span>
                    <h4>Toàn Quốc</h4>
                    <p>Mở rộng ra Hà Nội, Đà Nẵng và các tỉnh thành lớn với 50+ chi nhánh.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot active"></div>
                <div class="timeline-content">
                    <span class="timeline-year">2024</span>
                    <h4>Hướng Tới Tương Lai</h4>
                    <p>Phục vụ 1M+ khách hàng, tiếp tục đổi mới và phát triển bền vững.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values Section -->
<section class="values-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-label">Giá Trị Cốt Lõi</span>
            <h2 class="section-title-premium">Điều Chúng Tôi <span class="text-gradient">Tin Tưởng</span></h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <h4>Chất Lượng</h4>
                    <p>Cam kết sử dụng hạt cà phê tươi ngon, an toàn và quy trình pha chế chuẩn 5 sao.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h4>Khách Hàng</h4>
                    <p>Khách hàng là trung tâm của mọi quyết định. Sự hài lòng của bạn là thành công của chúng tôi.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-leaf"></i>
                    </div>
                    <h4>Bền Vững</h4>
                    <p>Cam kết bảo vệ môi trường thông qua bao bì thân thiện và quy trình xanh.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-lightbulb"></i>
                    </div>
                    <h4>Đổi Mới</h4>
                    <p>Không ngừng sáng tạo, cải tiến để mang đến trải nghiệm tốt nhất cho khách hàng.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-handshake"></i>
                    </div>
                    <h4>Cam Kết</h4>
                    <p>Giữ chữ tín với khách hàng, đối tác và cộng đồng trong mọi hoạt động.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <h4>Xuất Sắc</h4>
                    <p>Phấn đấu đạt tiêu chuẩn cao nhất trong mọi khía cạnh từ thức uống đến dịch vụ.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
/* ===== PAGE HEADER ===== */
.page-header {
    background: linear-gradient(135deg, #5D4037 0%, #3E2723 100%);
    padding: 100px 0 80px;
    text-align: center;
    color: white;
    position: relative;
    overflow: hidden;
}

.page-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 50%, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
}

.page-title {
    font-size: 3rem;
    font-weight: 900;
    margin-bottom: 1rem;
    position: relative;
}

.page-subtitle {
    font-size: 1.25rem;
    opacity: 0.9;
    position: relative;
}

/* ===== STORY SECTION ===== */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
}

.stat-card {
    background: linear-gradient(135deg, #EFEBE9 0%, #D7CCC8 100%);
    padding: 1.5rem;
    border-radius: 15px;
    text-align: center;
}

.stat-card h3 {
    font-size: 2rem;
    font-weight: 800;
    color: #5D4037;
    margin-bottom: 0.5rem;
}

.stat-card p {
    color: #3E2723;
    font-weight: 600;
    margin: 0;
}

.story-image-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    height: 600px;
}

.story-image {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
}

.story-img-1 {
    grid-row: 1 / 3;
}

.story-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
}

.story-image:hover img {
    transform: scale(1.1);
}

/* ===== TIMELINE ===== */
.timeline {
    position: relative;
    padding: 2rem 0;
    max-width: 800px;
    margin: 0 auto;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, #5D4037 0%, #3E2723 100%);
    transform: translateX(-50%);
}

.timeline-item {
    position: relative;
    margin-bottom: 3rem;
}

.timeline-item:nth-child(odd) .timeline-content {
    margin-left: auto;
    text-align: left;
}

.timeline-item:nth-child(even) .timeline-content {
    margin-right: auto;
    text-align: right;
}

.timeline-content {
    background: white;
    padding: 2rem;
    border-radius: 15px;
    width: 45%;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
}

.timeline-content:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(93, 64, 55, 0.2);
}

.timeline-dot {
    position: absolute;
    left: 50%;
    top: 0;
    width: 20px;
    height: 20px;
    background: white;
    border: 4px solid #5D4037;
    border-radius: 50%;
    transform: translateX(-50%);
    z-index: 10;
}

.timeline-dot.active {
    background: #5D4037;
    box-shadow: 0 0 0 10px rgba(93, 64, 55, 0.2);
    animation: pulse 2s infinite;
}

.timeline-year {
    display: inline-block;
    background: linear-gradient(135deg, #5D4037 0%, #3E2723 100%);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-weight: 700;
    margin-bottom: 1rem;
}

.timeline-content h4 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
}

.timeline-content p {
    color: var(--gray-600);
    margin: 0;
}

/* ===== VALUES SECTION ===== */
.value-card {
    background: white;
    padding: 2.5rem;
    border-radius: 20px;
    text-align: center;
    transition: all 0.4s ease;
    border: 2px solid var(--gray-200);
    height: 100%;
}

.value-card:hover {
    transform: translateY(-10px);
    border-color: #5D4037;
    box-shadow: 0 20px 40px rgba(93, 64, 55, 0.15);
}

.value-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #EFEBE9 0%, #D7CCC8 100%);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    transition: all 0.4s ease;
}

.value-card:hover .value-icon {
    background: linear-gradient(135deg, #5D4037 0%, #3E2723 100%);
    transform: rotateY(360deg);
}

.value-icon i {
    font-size: 2rem;
    color: #5D4037;
    transition: all 0.4s ease;
}

.value-card:hover .value-icon i {
    color: white;
}

.value-card h4 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
}

.value-card p {
    color: var(--gray-600);
    line-height: 1.7;
    margin: 0;
}

/* ===== TEAM SECTION ===== */
.team-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    transition: all 0.4s ease;
}

.team-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(93, 64, 55, 0.2);
}

.team-image {
    position: relative;
    overflow: hidden;
    height: 300px;
}

.team-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: all 0.4s ease;
}

.team-card:hover .team-image img {
    transform: scale(1.1);
}

.team-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(93, 64, 55, 0.95) 0%, rgba(62, 39, 35, 0.95) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: all 0.4s ease;
}

.team-card:hover .team-overlay {
    opacity: 1;
}

.team-social {
    display: flex;
    gap: 1rem;
}

.team-social a {
    width: 45px;
    height: 45px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #5D4037;
    transition: all 0.3s ease;
    transform: translateY(20px);
}

.team-card:hover .team-social a {
    transform: translateY(0);
}

.team-social a:hover {
    background: #5D4037;
    color: white;
    transform: translateY(-3px);
}

.team-info {
    padding: 1.5rem;
    text-align: center;
}

.team-info h5 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
}

.team-info span {
    color: var(--gray-600);
    font-size: 0.9rem;
}

/* ===== RESPONSIVE ===== */
@@media (max-width: 992px) {
    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .story-image-grid {
        grid-template-columns: 1fr;
        height: auto;
    }
    
    .story-img-1 {
        grid-row: auto;
    }
    
    .story-image {
        height: 300px;
    }
    
    .timeline::before {
        left: 30px;
    }
    
    .timeline-dot {
        left: 30px;
    }
    
    .timeline-item:nth-child(odd) .timeline-content,
    .timeline-item:nth-child(even) .timeline-content {
        width: calc(100% - 80px);
        margin-left: 80px;
        text-align: left;
    }
}

@@media (max-width: 768px) {
    .page-title {
        font-size: 2rem;
    }
    
    .stats-grid {
        grid-template-columns: 1fr;
    }
}
</style>
