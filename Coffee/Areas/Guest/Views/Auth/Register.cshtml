@model FastFood.Models.Auth.RegisterModel

@{
    ViewData["Title"] = "Đăng Ký";
    Layout = "~/Areas/Guest/Views/Shared/_Layout.cshtml";
}

<section class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="auth-card">
                    <div class="auth-tabs">
                        <a asp-area="Guest" asp-controller="Auth" asp-action="Login" class="auth-tab">Đăng Nhập</a>
                        <a asp-area="Guest" asp-controller="Auth" asp-action="Register" class="auth-tab active">Đăng Ký</a>
                    </div>

                    <div class="auth-header">
                        <h2>Tham Gia Cùng Chúng Tôi!</h2>
                        <p>Đăng ký tài khoản để nhận nhiều ưu đãi hấp dẫn</p>
                    </div>

                    <form asp-area="Guest" asp-controller="Auth" asp-action="Register" method="post" class="auth-form">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-group-premium">
                                    <label class="form-label" asp-for="Username">Tên đăng nhập *</label>
                                    <div class="input-with-icon">
                                        <i class="fas fa-user-circle"></i>
                                        <input asp-for="Username" class="form-control" placeholder="username123" />
                                    </div>
                                    <span asp-validation-for="Username" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-premium">
                                    <label class="form-label" asp-for="FullName">Họ tên *</label>
                                    <div class="input-with-icon">
                                        <i class="fas fa-user"></i>
                                        <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                                    </div>
                                    <span asp-validation-for="FullName" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-premium">
                                    <label class="form-label" asp-for="Email">Email *</label>
                                    <div class="input-with-icon">
                                        <i class="fas fa-envelope"></i>
                                        <input asp-for="Email" class="form-control" placeholder="email@gmail.com" />
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-premium">
                                    <label class="form-label" asp-for="PhoneNumber">Số điện thoại *</label>
                                    <div class="input-with-icon">
                                        <i class="fas fa-phone"></i>
                                        <input asp-for="PhoneNumber" class="form-control" placeholder="0123456789" />
                                    </div>
                                    <span asp-validation-for="PhoneNumber" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-premium">
                                    <label class="form-label" asp-for="Password">Mật khẩu *</label>
                                    <div class="input-with-icon">
                                        <i class="fas fa-lock"></i>
                                        <input asp-for="Password" class="form-control" placeholder="••••••••" id="password" />
                                        <button type="button" class="toggle-password" onclick="togglePassword('password', 'toggleIcon1')">
                                            <i class="fas fa-eye" id="toggleIcon1"></i>
                                        </button>
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-premium">
                                    <label class="form-label" asp-for="ConfirmPassword">Xác nhận mật khẩu *</label>
                                    <div class="input-with-icon">
                                        <i class="fas fa-lock"></i>
                                        <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" id="confirmPassword" />
                                        <button type="button" class="toggle-password" onclick="togglePassword('confirmPassword', 'toggleIcon2')">
                                            <i class="fas fa-eye" id="toggleIcon2"></i>
                                        </button>
                                    </div>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group-premium">
                            <label class="terms-checkbox">
                                <input type="checkbox" name="AcceptTerms" required>
                                <span class="checkmark"></span>
                                Tôi đồng ý với <a href="#">Điều khoản sử dụng</a> và <a href="#">Chính sách bảo mật</a>
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="fas fa-user-plus me-2"></i>Đăng Ký Ngay
                        </button>

                        <div class="auth-footer">
                            Đã có tài khoản?
                            <a asp-area="Guest" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                        </div>
                    </form>
                </div>

                <!-- Benefits Section -->
                <div class="benefits-grid mt-4">
                    <div class="benefit-item">
                        <i class="fas fa-gift"></i>
                        <span>Giảm 20% đơn đầu</span>
                    </div>
                    <div class="benefit-item">
                        <i class="fas fa-shipping-fast"></i>
                        <span>Freeship tháng đầu</span>
                    </div>
                    <div class="benefit-item">
                        <i class="fas fa-star"></i>
                        <span>Tích điểm x2</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
.auth-section {
    padding: 6rem 0;
    background: linear-gradient(135deg, #FDF6EE 0%, #FFFFFF 50%, #FDF6EE 100%);
    min-height: 100vh;
    display: flex;
    align-items: center;
}

.auth-card {
    background: white;
    border-radius: 40px;
    padding: 0;
    box-shadow: 0 30px 80px rgba(111, 78, 55, 0.08); /* Coffee brown */
    overflow: hidden;
    border: 1px solid rgba(111, 78, 55, 0.05);
}

.auth-tabs {
    display: flex;
    background: #F9FAFB;
    border-bottom: 1px solid #F3F4F6;
}

.auth-tab {
    flex: 1;
    text-align: center;
    padding: 1.5rem;
    font-weight: 700;
    color: var(--gray-500);
    text-decoration: none;
    transition: all 0.3s ease;
}

.auth-tab:hover {
    color: var(--primary-red);
    background: rgba(111, 78, 55, 0.02);
}

.auth-tab.active {
    color: var(--primary-red);
    background: white;
    border-bottom: 3px solid var(--primary-red);
}

.auth-header {
    text-align: center;
    padding: 3rem 3rem 1rem;
}

.auth-form {
    padding: 0 3rem 3rem;
}

.terms-checkbox {
    display: flex;
    align-items: start;
    gap: 0.75rem;
    cursor: pointer;
    user-select: none;
    font-size: 0.9rem;
    color: var(--gray-700);
    line-height: 1.7;
}

.terms-checkbox input[type="checkbox"] {
    display: none;
}

.terms-checkbox .checkmark {
    width: 22px;
    height: 22px;
    border: 2px solid var(--gray-300);
    border-radius: 6px;
    flex-shrink: 0;
    margin-top: 2px;
    transition: all 0.3s ease;
}

.terms-checkbox input:checked ~ .checkmark {
    background: var(--gradient-red);
    border-color: var(--primary-red);
}

.terms-checkbox input:checked ~ .checkmark::after {
    content: '\f00c';
    font-family: 'Font Awesome 6 Free';
    font-weight: 900;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: white;
    font-size: 0.75rem;
}

.terms-checkbox a {
    color: var(--primary-red);
    text-decoration: none;
    font-weight: 600;
}

.terms-checkbox a:hover {
    text-decoration: underline;
}

.benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
}

.benefit-item {
    background: white;
    padding: 1.5rem;
    border-radius: 15px;
    text-align: center;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
}

.benefit-item i {
    font-size: 2rem;
    color: var(--primary-red);
    display: block;
    margin-bottom: 0.75rem;
}

.benefit-item span {
    font-weight: 600;
    color: var(--gray-700);
    font-size: 0.9rem;
}

@@media (max-width: 768px) {
    .benefits-grid {
        grid-template-columns: 1fr;
    }
}
</style>

<script>
function togglePassword(inputId, iconId) {
    const passwordInput = document.getElementById(inputId);
    const icon = document.getElementById(iconId);

    if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
    } else {
        passwordInput.type = 'password';
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
    }
}

// Password strength indicator (optional enhancement)
document.getElementById('password')?.addEventListener('input', function() {
    // Add password strength logic here if desired
});
</script>
