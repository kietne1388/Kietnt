    alert('Tính năng đăng nhập Google đang được phát triển.\n\nĐể kích hoạt, cần cấu hình Google OAuth2 Client ID trong appsettings.json');
    
    // Example flow after getting Google token:
    // const externalLoginData = {
    //     provider: 'Google',
    //     email: 'user@gmail.com',
    //     fullName: 'User Name'
    // };
    // callExternalLoginApi(externalLoginData);
}

function loginWithFacebook() {
    // For production: Use Facebook Login SDK
    // https://developers.facebook.com/docs/facebook-login/web
    
    alert('Tính năng đăng nhập Facebook đang được phát triển.\n\nĐể kích hoạt, cần cấu hình Facebook App ID trong appsettings.json');
    
    // Example flow after getting Facebook token:
    // const externalLoginData = {
    //     provider: 'Facebook',
    //     email: 'user@facebook.com',
    //     fullName: 'User Name'
    // };
    // callExternalLoginApi(externalLoginData);
}

async function callExternalLoginApi(loginData) {
    try {
        const response = await fetch('/api/auth/external-login', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(loginData)
        });
        
        if (response.ok) {
            const result = await response.json();
            // Redirect to user home on success
            window.location.href = '/User/Home';
        } else {
            alert('Đăng nhập thất bại. Vui lòng thử lại.');
        }
    } catch (error) {
        console.error('External login error:', error);
        alert('Có lỗi xảy ra. Vui lòng thử lại.');
    }
}
</script>

