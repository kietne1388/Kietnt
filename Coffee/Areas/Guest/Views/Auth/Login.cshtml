@model FastFood.Models.Auth.LoginModel

@{
    ViewData["Title"] = "Đăng Nhập";
    Layout = "~/Areas/Guest/Views/Shared/_Layout.cshtml";
}

<section class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">
                <div class="auth-card">
                    <div class="auth-tabs">
                        <a asp-area="Guest" asp-controller="Auth" asp-action="Login" class="auth-tab active">Đăng Nhập</a>
                        <a asp-area="Guest" asp-controller="Auth" asp-action="Register" class="auth-tab">Đăng Ký</a>
                    </div>

                    <div class="auth-header">
                        <h2>Chào Mừng Trở Lại!</h2>
                        <p>Đăng nhập để thưởng thức những tách cà phê tuyệt hảo</p>
                    </div>

                    <form asp-area="Guest" asp-controller="Auth" asp-action="Login" method="post" class="auth-form">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="form-group-premium">
                            <label asp-for="Username" class="form-label">Tên đăng nhập hoặc Email</label>
                            <div class="input-with-icon">
                                <i class="fas fa-user"></i>
                                <input asp-for="Username" class="form-control" placeholder="Nhập tên đăng nhập hoặc email" />
                            </div>
                            <span asp-validation-for="Username" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="form-group-premium">
                            <label asp-for="Password" class="form-label">Mật khẩu</label>
                            <div class="input-with-icon">
                                <i class="fas fa-lock"></i>
                                <input asp-for="Password" class="form-control" placeholder="••••••••" id="password" />
                                <button type="button" class="toggle-password" onclick="togglePassword()">
                                    <i class="fas fa-eye" id="toggleIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="form-options">
                            <label class="remember-checkbox">
                                <input asp-for="RememberMe" type="checkbox" />
                                <span class="checkmark"></span>
                                Ghi nhớ đăng nhập
                            </label>
                            <a href="#" class="forgot-password">Quên mật khẩu?</a>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="fas fa-sign-in-alt me-2"></i>Đăng Nhập
                        </button>

                        <div class="divider">
                            <span>hoặc</span>
                        </div>

                        <div class="social-login">
                            <button type="button" class="btn-social google" onclick="loginWithGoogle()">
                                <i class="fab fa-google"></i>
                                Google
                            </button>
                            <button type="button" class="btn-social facebook" onclick="loginWithFacebook()">
                                <i class="fab fa-facebook-f"></i>
                                Facebook
                            </button>
                        </div>

                        <div class="auth-footer">
                            Chưa có tài khoản?
                            <a asp-area="Guest" asp-controller="Auth" asp-action="Register">Đăng ký ngay</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
.auth-section {
    padding: 6rem 0;
    background: linear-gradient(135deg, #FDF6EE 0%, #FFFFFF 50%, #FDF6EE 100%);
    min-height: 100vh;
    display: flex;
    align-items: center;
}

.auth-card {
    background: white;
    border-radius: 40px;
    padding: 0;
    box-shadow: 0 30px 80px rgba(111, 78, 55, 0.08); /* Coffee brown shadow */
    overflow: hidden;
    border: 1px solid rgba(111, 78, 55, 0.05); /* Coffee brown border */
}

.auth-tabs {
    display: flex;
    background: #F9FAFB;
    border-bottom: 1px solid #F3F4F6;
}

.auth-tab {
    flex: 1;
    text-align: center;
    padding: 1.5rem;
    font-weight: 700;
    color: var(--gray-500);
    text-decoration: none;
    transition: all 0.3s ease;
}

.auth-tab:hover {
    color: var(--primary-red);
    background: rgba(111, 78, 55, 0.02);
}

.auth-tab.active {
    color: var(--primary-red);
    background: white;
    border-bottom: 3px solid var(--primary-red);
}

.auth-header {
    text-align: center;
    padding: 3rem 3rem 1rem;
}

.auth-form {
    padding: 0 3rem 3rem;
}

.auth-logo {
    width: 60px;
    height: 60px;
    background: var(--gradient-red);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
}

.auth-logo i {
    font-size: 2.5rem;
    color: white;
}

.auth-header h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: var(--gray-900);
}

.auth-header p {
    color: var(--gray-600);
    margin: 0;
}

.form-group-premium {
    margin-bottom: 1.5rem;
}

.input-with-icon {
    position: relative;
}

.input-with-icon i.fa-user,
.input-with-icon i.fa-lock {
    position: absolute;
    left: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--gray-400);
    font-size: 1.1rem;
}

.input-with-icon .form-control {
    padding-left: 3.5rem;
    padding-right: 3.5rem;
    height: 55px;
    border-radius: 15px;
    border: 2px solid var(--gray-300);
    transition: all 0.3s ease;
}

.input-with-icon .form-control:focus {
    border-color: var(--primary-red);
    box-shadow: 0 0 0 4px var(--primary-red-lightest);
}

.toggle-password {
    position: absolute;
    right: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--gray-400);
    cursor: pointer;
    padding: 0.5rem;
}

.toggle-password:hover {
    color: var(--primary-red);
}

.form-options {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
}

.remember-checkbox {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    user-select: none;
}

.remember-checkbox input[type="checkbox"] {
    display: none;
}

.checkmark {
    width: 22px;
    height: 22px;
    border: 2px solid var(--gray-300);
    border-radius: 6px;
    position: relative;
    transition: all 0.3s ease;
}

.remember-checkbox input:checked ~ .checkmark {
    background: var(--gradient-red);
    border-color: var(--primary-red);
}

.remember-checkbox input:checked ~ .checkmark::after {
    content: '\f00c';
    font-family: 'Font Awesome 6 Free';
    font-weight: 900;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: white;
    font-size: 0.75rem;
}

.forgot-password {
    color: var(--primary-red);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
}

.forgot-password:hover {
    text-decoration: underline;
}

.divider {
    position: relative;
    text-align: center;
    margin: 2rem 0;
}

.divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--gray-300);
}

.divider span {
    position: relative;
    background: white;
    padding: 0 1rem;
    color: var(--gray-500);
    font-size: 0.9rem;
}

.social-login {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
}

.btn-social {
    border: 2px solid var(--gray-300);
    background: white;
    padding: 0.875rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
}

.btn-social:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
}

.btn-social.google:hover {
    border-color: #DB4437;
    color: #DB4437;
}

.btn-social.facebook:hover {
    border-color: #4267B2;
    color: #4267B2;
}

.auth-footer {
    text-align: center;
    color: var(--gray-600);
    padding-top: 1.5rem;
    border-top: 1px solid var(--gray-200);
}

.auth-footer a {
    color: var(--primary-red);
    font-weight: 700;
    text-decoration: none;
}

.auth-footer a:hover {
    text-decoration: underline;
}

@@media (max-width: 768px) {
    .auth-card {
        padding: 2rem 1.5rem;
    }

    .social-login {
        grid-template-columns: 1fr;
    }
}
</style>

<script>
function togglePassword() {
    const passwordInput = document.getElementById('password');
    const icon = document.getElementById('toggleIcon');

    if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
    } else {
        passwordInput.type = 'password';
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
    }
}

// Social Login Functions
// Note: These functions show the flow. For production, integrate with Google/Facebook SDK
