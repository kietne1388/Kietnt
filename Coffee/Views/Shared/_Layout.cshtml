<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FastFood</title>
    
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body, h1, h2, h3, h4, h5, h6, .navbar-brand, .nav-link, .btn, .form-control { 
            font-family: 'Times New Roman', Times, serif !important; 
        }
    </style>
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="Guest" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-hamburger me-2"></i>FastFood
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Guest" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Guest" asp-controller="Product" asp-action="Index">
                                <i class="fas fa-pizza-slice me-1"></i>Sản phẩm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Guest" asp-controller="Combo" asp-action="Index">
                                <i class="fas fa-box me-1"></i>Combo
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Guest" asp-controller="Home" asp-action="About">
                                <i class="fas fa-info-circle me-1"></i>Về chúng tôi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Guest" asp-controller="Home" asp-action="Contact">
                                <i class="fas fa-envelope me-1"></i>Liên hệ
                            </a>
                        </li>
                    </ul>
                    
                    <!-- Search Bar -->
                    <form class="d-flex me-3" asp-area="Guest" asp-controller="Search" asp-action="Index" method="get">
                        <div class="input-group">
                            <input class="form-control" type="search" name="keyword" placeholder="Tìm kiếm..." aria-label="Search">
                            <button class="btn btn-light" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>
                    
                    <!-- User Menu -->
                    <ul class="navbar-nav">
                        @if (Context.Session.GetInt32("UserId").HasValue)
                        {
                            var userName = Context.Session.GetString("UserName") ?? "User";
                            var userRole = Context.Session.GetString("UserRole") ?? "Customer";
                            
                            <li class="nav-item">
                                <a class="nav-link position-relative" asp-area="User" asp-controller="Cart" asp-action="Index">
                                    <i class="fas fa-shopping-cart"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                        0
                                    </span>
                                </a>
                            </li>
                            
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-1"></i>@userName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @if (userRole == "Admin")
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                                <i class="fas fa-tachometer-alt me-2"></i>Dashboard Admin
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li>
                                        <a class="dropdown-item" asp-area="User" asp-controller="Profile" asp-action="Index">
                                            <i class="fas fa-user me-2"></i>Hồ sơ
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="User" asp-controller="Order" asp-action="Index">
                                            <i class="fas fa-receipt me-2"></i>Đơn hàng
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="User" asp-controller="Voucher" asp-action="MyVouchers">
                                            <i class="fas fa-ticket-alt me-2"></i>Voucher
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Guest" asp-controller="Register" asp-action="Logout">
                                            <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Guest" asp-controller="Register" asp-action="Login">
                                    <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm ms-2" asp-area="Guest" asp-controller="Register" asp-action="Register">
                                    <i class="fas fa-user-plus me-1"></i>Đăng ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <main class="flex-fill">
        
        @RenderBody()
    </main>
    
    <footer class="bg-dark text-white mt-5 py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5><i class="fas fa-hamburger me-2"></i>FastFood</h5>
                    <p class="text-muted">Hệ thống đồ ăn nhanh chất lượng cao, phục vụ nhanh chóng và tiện lợi.</p>
                    <div class="social-links">
                        <a href="#" class="text-white me-3"><i class="fab fa-facebook fa-lg"></i></a>
                        <a href="#" class="text-white me-3"><i class="fab fa-instagram fa-lg"></i></a>
                        <a href="#" class="text-white me-3"><i class="fab fa-twitter fa-lg"></i></a>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Liên kết</h5>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-muted text-decoration-none">Về chúng tôi</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Sản phẩm</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Combo đặc biệt</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Liên hệ</h5>
                    <ul class="list-unstyled text-muted">
                        <li><i class="fas fa-map-marker-alt me-2"></i>123 Đường ABC, Quận 1, TP.HCM</li>
                        <li><i class="fas fa-phone me-2"></i>0123 456 789</li>
                        <li><i class="fas fa-envelope me-2"></i>contact@fastfood.vn</li>
                    </ul>
                </div>
            </div>
            <hr class="bg-secondary">
            <div class="text-center text-muted">
                <small>&copy; 2024 FastFood. All rights reserved.</small>
            </div>
        </div>
    </footer>
    
    <!-- Bootstrap 5.3 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery (optional) -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <!-- Custom JS -->
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Toast Containers -->
    <div id="toastContainerCenter" class="toast-container center"></div>
    <div id="toastContainerTopRight" class="toast-container top-right"></div>
    <div id="toastContainerBottomRight" class="toast-container bottom-right"></div>

    <script>
        // Modern Notification System
        function showToast(message, type = 'success', position = 'top-right') {
            const containerMap = {
                'center': 'toastContainerCenter',
                'top-right': 'toastContainerTopRight',
                'bottom-right': 'toastContainerBottomRight'
            };
            
            const containerId = containerMap[position] || 'toastContainerTopRight';
            const container = document.getElementById(containerId);
            if (!container) return;
            
            const toast = document.createElement('div');
            toast.className = `custom-toast toast-${type}`;
            
            const iconMap = {
                'success': 'fa-check-circle',
                'error': 'fa-exclamation-circle',
                'warning': 'fa-exclamation-triangle',
                'info': 'fa-info-circle'
            };
            
            const icon = iconMap[type] || 'fa-info-circle';
            
            toast.innerHTML = `
                <i class="fas ${icon} me-3"></i>
                <div class="toast-content">${message}</div>
                <button class="toast-close" onclick="this.parentElement.remove()">
                    <i class="fas fa-times"></i>
                </button>
            `;
            
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                if (position === 'center') {
                    toast.style.transform = 'translateY(-20px)';
                } else {
                    toast.style.transform = 'translateX(20px)';
                }
                setTimeout(() => toast.remove(), 500);
            }, 4000);
        }

        // Override default alert
        window.alert = function(message) {
            showToast(message, 'warning', 'center');
        };

        // Handle TempData messages
        @if (TempData["Success"] != null) {
            <text>showToast('@TempData["Success"]', 'success', 'top-right');</text>
        }
        @if (TempData["Error"] != null) {
            <text>showToast('@TempData["Error"]', 'error', 'top-right');</text>
        }
    </script>
</body>
</html>
